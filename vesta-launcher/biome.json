{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"extends": "//",
	"formatter": {
		"indentWidth": 2,
		"lineWidth": 80
	},
	"files": {
		"includes": [
			"src/**",
			"ui/**",
			"package.json",
			"tsconfig.json",
			"vite.config.ts",
			"vitest.config.ts",
			"index.html",
			"other.html",
			"biome.json",
			"!dist",
			"!node_modules",
			"!target",
			"!src-tauri/target",
			"!build",
			"!.next",
			"!.nuxt",
			"!.output",
			"!.vercel",
			"!.netlify",
			"!coverage",
			"!**/*.tsbuildinfo",
			"!**/*.d.ts",
			"!**/*.d.tsx"
		]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	}
}
